<root>
	<styles>
		<include src="file://{resources}/styles/custom_game/courier.css" />
	</styles>

	<scripts>
		<include src="file://{resources}/scripts/custom_game/key_bindings.js" />
	</scripts>

	<Panel class="courier-panel">
        <Button class="button-hidden" id="select-courier-button" onactivate="OnCustomeGameSelectCourier()">
			<Image src="file://{images}/custom_game/courier_icon.png" />
		</Button>
		<Button id="courier-send-button" class="send-button-no-send" onactivate="OnCustomGameCourierSend()">
			<Image src="file://{images}/custom_game/courier_transfer_item.png" />
		</Button>
		<Image id="courier-ip" class="image-hidden" src="file://{images}/custom_game/turn_rate_icon.png" />
    </Panel>
</root>
