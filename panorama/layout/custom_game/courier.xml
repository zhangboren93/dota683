<root>
	<styles>
		<include src="file://{resources}/styles/custom_game/courier.css" />
	</styles>

	<scripts>
		<include src="file://{resources}/scripts/custom_game/key_bindings.js" />
	</scripts>

	<Panel class="courier-panel">
		<Label id="courier-respawn-remaining"/>
		<Button id="courier-select-button" class="button-hidden" onactivate="OnCustomeGameSelectCourier()">
			<Image src="file://{images}/custom_game/courier_icon.png"/>
		</Button>
		<Button id="courier-select-next-button" class="button-hidden" onactivate="OnCustomGameSelectNextCourier()">
			<DOTAHeroImage id="current-courier-owner-image" heroname="npc_dota_hero_antimage" heroimagestyle="icon"/>
		</Button>
		<Button id="courier-send-button" class="send-button-no-send button-hidden" onactivate="OnCustomGameCourierSend()">
			<Image id="courier-send-image" src="file://{images}/custom_game/courier_transfer_item.png" />
			<DOTAHeroImage id="courier-target-hero" class="image-hidden" heroname="npc_dota_hero_antimage" heroimagestyle="icon"/>
		</Button>
		<Image id="courier-ip" class="image-hidden" src="file://{images}/custom_game/turn_rate_icon.png" />
    </Panel>
</root>
