<root>
	<styles>
		<include src="file://{resources}/styles/custom_game/courier.css" />
	</styles>

	<scripts>
		<include src="file://{resources}/scripts/custom_game/key_bindings.js" />
	</scripts>

	<Panel class="courier-panel">
		<Label id="courier-respawn-remaining"/>
