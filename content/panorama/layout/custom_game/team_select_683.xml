<root>
	<styles>
		<!--include src="file://{resources}/styles/dotastyles.css" />
		<include src="file://{resources}/styles/battle_pass/current_battle_pass.css" />	
		<include src="file://{resources}/styles/play.css" /-->
		<include src="file://{resources}/styles/custom_game/team_select.css" />
		<include src="file://{resources}/styles/custom_game/team_select_683.css" />
	</styles>
	<scripts>
		<include src="file://{resources}/scripts/custom_game/team_select.js" />
		<include src="file://{resources}/scripts/custom_game/team_select_683.js"/>
	</scripts>
	<Panel hittest="false" class="TeamSelect">
		<Panel hittest="false" id="TeamSelectContainer" selectionpos="auto">
			<!--Empty space to let the loading screen and chat be visible-->
			<Panel hittest="false" id="TeamsSelectEmptySpace" />

			<Panel id="ModeSelect" style="visibility: collapse;">
				<Panel style="flow-children: right;">
					<Label text="#683modeselect_gamemode"/>
					<Panel id="ModeSelectRadios">
						<RadioButton group="mode" id="ap" text="AP" onactivate="handleModeSelect('ap')"/>
						<RadioButton group="mode" id="rd" text="RD" onactivate="handleModeSelect('rd')"/>
						<RadioButton group="mode" id="js" text="JS" onactivate="handleModeSelect('js')"/>
						<RadioButton group="mode" id="dm" text="DM" onactivate="handleModeSelect('dm')"/>
						<RadioButton group="mode" id="sp" text="SP" onactivate="handleModeSelect('sp')"/>
						<RadioButton group="mode" id="cm" text="CM" onactivate="handleModeSelect('cm')"/>
						<RadioButton group="mode" id="cd" text="CD" onactivate="handleModeSelect('cd')"/>
					</Panel>
				</Panel>
				<Panel style="flow-children: right;">
					<Label text="#683modeselect_first_pick_team"/>
					<Panel id="FirstTeamRadios" style="flow-children: down;">
						<RadioButton group="first_pick" id="random" text="#683modeselect_first_pick_random" onactivate="handleFirstPick('random')"/>
						<RadioButton group="first_pick" id="rad" text="#683modeselect_first_pick_rad" onactivate="handleFirstPick('rad')"/>
						<RadioButton group="first_pick" id="dire" text="#683modeselect_first_pick_dire" onactivate="handleFirstPick('dire')"/>
					</Panel>
				</Panel>
				<Panel id="ModelSelectToggleOptions" style="flow-children: down;">
					<ToggleButton id="sp" checked="false" text="#683modeselect_gamemode_samepick" onactivate="handleSamePickToggle()" />
				</Panel>
				<Panel style="flow-children: right;">
					<Label text="#683modeselect_meta_version"/>
					<Panel id="MetaVersionRadio" style="flow-children: down;">
						<RadioButton group="meta_version" id="683" text="#683modeselect_meta_version_683" onactivate="handleMetaVersion('683')"/>
						<RadioButton group="meta_version" id="688" text="#683modeselect_meta_version_688" onactivate="handleMetaVersion('688')"/>
					</Panel>
				</Panel>
			</Panel>
			<!--Teams List, left hand panel-->
			<Panel id="TeamsList" >
				<Panel id="TeamsListGroup" >
					<Panel id="TeamListHeader">
						<Label id="TeamListHeaderLabel" text="#custom_game_team_select" />
						<Image id="TeamListLockedIcon" src="file://{images}/control_icons/lock_small.png" />
					</Panel>
					<!--Panel id="SpectTeamsList">
						<Panel id="SpectTeamsListInner">
							<Label text="#683modeselect_referee" id="referee_title"/>
							<Label text="#683modeselect_referee_empty" class="referee_empty" id="referee_slot_1"/>
							<Label text="#683modeselect_referee_empty" class="referee_empty"/>
						</Panel>
						<Button id="SpectTeamsListButton" onactivate="handleJoinSpectTeam()"/>
					</Panel-->
					<Panel id="TeamsListRoot" />
					<Button id="ShuffleTeamAssignmentButton" onactivate="OnShufflePlayersPressed()">
						<Label text="#custom_game_team_select_shuffle" />
						<Image src="file://{images}/custom_game/shuffle.png" />
					</Button>
				</Panel>
			</Panel>

			<!--Game Info and Unassigned players, right hand panel-->
			<Panel id="GameAndPlayersRoot">
				
				<Panel id="GameInfoPanel" >
					
					<!--Game mode and map-->
					<Panel id="CustomGameModeName">
						<Label id="GameModeNameLabel" text="#addon_game_name" />
					</Panel>
					<Panel id="MapInfo">
						<Label id="MapInfoLabel" text="#LoadingScreenMapInfo" />
					</Panel>
					
					<!--Countdown timer-->
					<Panel id="StartGameCountdownTimer">
						<Image id="TimerBg" src="file://{images}/status_icons/timer_background.psd" />
						<Image id="TimerRing" src="file://{images}/status_icons/timer_ring.psd" />
						<Label id="TeamSelectTimer" text="#custom_game_team_select_timer" />
						<Panel id="TimerLabelBox" >
							<Label id="TimerLabelAutoStart" text="#custom_game_team_select_auto_start" />
							<Label id="TimerLabelGameStart" text="#custom_game_team_select_starting" />
						</Panel>
					</Panel>
					
				</Panel>

				<!--Unassigned players-->
				<Panel id="UnassignedPlayerPanel" >
					<Button id="UnassignedPlayersButton" onactivate="OnLeaveTeamPressed()">
						<Panel id="UnassignedPlayersHeader">
							<Label text="#custom_game_team_select_unassigned_players" />
						</Panel>
						<Panel id="UnassignedPlayersDivider" />
						<Panel id="UnassignedPlayersContainer" />
					</Button>		
				
					<Button id="AutoAssignButton" onactivate="OnAutoAssignPressed()">
						<Image src="file://{images}/custom_game/double_arrow_left.png" />
						<Label text="#custom_game_team_select_auto_assign" />
					</Button>
				</Panel>
				
				<!--Start and lock button-->
				<Button id="LockAndStartButton" class="PlayButton" onactivate="OnLockAndStartPressed()">
					<Label text="#custom_game_team_select_lock_start" />
				</Button>
				<Button id="CancelAndUnlockButton" class="PlayButton" onactivate="OnCancelAndUnlockPressed()">
					<Label text="#custom_game_team_select_cancel_unlock" />
				</Button>
				
			</Panel>
		</Panel>
		<Button id="mode_select_block_button">
			<Label text="#683modeselect_mode_selectable_by_host"/>
		</Button>
	</Panel>
</root>
